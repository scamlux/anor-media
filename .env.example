# Shared
NODE_ENV=development
LOG_LEVEL=info

# Backend
BACKEND_PORT=4000
BACKEND_BASE_URL=http://localhost:4000
JWT_SECRET=change_me
JWT_EXPIRES_IN=8h
COOKIE_NAME=anor_token

# PostgreSQL
POSTGRES_DB=anor_media
POSTGRES_USER=anor
POSTGRES_PASSWORD=anor_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://anor:anor_password@postgres:5432/anor_media

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# AI Orchestrator
AI_ORCHESTRATOR_URL=http://ai-orchestrator:8000
AI_ORCHESTRATOR_API_KEY=change_me
PRIMARY_LLM_PROVIDER=openai
FALLBACK_LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_APP_NAME=ANOR_MEDIA

# Queue and Limits
PLAN_PERIOD_MAX_DAYS=90
POST_GENERATION_DAILY_LIMIT=20
PROJECT_COST_MONTHLY_LIMIT=1000

# Monitoring
SENTRY_DSN=
PROMETHEUS_ENABLED=true
